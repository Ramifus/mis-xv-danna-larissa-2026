<section
    class="relative text-black w-full overflow-x-hidden"
    style="background-image: url('/imagenes/fondomono.png'); background-size: cover; background-position: center; background-repeat: no-repeat;"
>
    <div class="flex justify-center pt-36 sm:pt-40 md:pt-44" id="corona">
        <img
            src="/imagenes/Corona.webp"
            alt="Corona de quinceañera"
            class="w-20 h-auto sm:w-24 md:w-28 lg:w-32 xl:w-36 object-contain"
        />
    </div>

    <div class="relative w-full pt-8 sm:pt-10 md:pt-12 overflow-hidden px-4">
        <div class="flex justify-center w-full">
            <div class="text-center z-10 max-w-4xl w-full">
                <div
                    class="relative text-center z-30 mb-8 w-full"
                    id="titulo-container"
                >
                    <h1
                        class="font-crimson text-2xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl text-[#800020] font-bold tracking-wider"
                        id="titulo"
                    >
                        MIS XV AÑOS
                    </h1>
                </div>

                <div
                    class="flex items-center justify-center gap-4 sm:gap-8 md:gap-16 lg:gap-24 mb-8 w-full"
                    id="nombre-container"
                >
                    <div id="mariposa-izq" class="flex-shrink-0">
                        <img
                            src="/gif/MariposaRoja.gif"
                            alt="Mariposa izquierda"
                            class="w-10 h-auto sm:w-8 sm:h-8 md:w-10 md:h-10 lg:w-12 lg:h-12 object-contain"
                        />
                    </div>

                    <h2
                        class="font-great-vibes text-6xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-[#a27735] tracking-wide flex-shrink min-w-0 leading-tight"
                        id="nombre-typewriter"
                    >
                    </h2>

                    <div id="mariposa-der" class="flex-shrink-0">
                        <img
                            src="/gif/MariposaRoja.gif"
                            alt="Mariposa derecha"
                            class="w-10 h-auto sm:w-8 sm:h-8 md:w-10 md:h-10 lg:w-12 lg:h-12 object-contain scale-x-[-1]"
                        />
                    </div>
                </div>

                <div
                    class="relative w-full overflow-visible"
                    id="foto-container"
                >
                    <div class="relative flex justify-center">
                        <img
                            src="/imagenes/mis.png"
                            alt="Foto de quinceañera"
                            class="w-full max-w-[50vw] h-auto sm:max-w-[42vw] md:max-w-[35vw] lg:max-w-[28vw] xl:max-w-[22vw] object-contain"
                            id="foto-quinceañera"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        // CORONA - Zoom in
        gsap.fromTo(
            "#corona",
            { opacity: 0, scale: 0.5 },
            {
                opacity: 1,
                scale: 1,
                duration: 1.2,
                ease: "back.out(1.2)",
                delay: 0.3,
            },
        );

        // TÍTULO - Fade in de arriba
        gsap.fromTo(
            "#titulo",
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 1, ease: "power2.out", delay: 0.5 },
        );

        // MARIPOSA IZQUIERDA - Llega de la izquierda
        gsap.fromTo(
            "#mariposa-izq",
            { opacity: 0, x: -50, y: 20, rotation: -15, scale: 0.8 },
            {
                opacity: 1,
                x: 0,
                y: 0,
                rotation: 0,
                scale: 1,
                duration: 4,
                ease: "power2.out",
            },
        );

        gsap.to("#mariposa-izq", {
            y: -12,
            rotation: 3,
            duration: 3,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
        });

        gsap.to("#mariposa-izq", {
            x: 10,
            duration: 4,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
        });

        // MARIPOSA DERECHA - Llega de la derecha
        gsap.fromTo(
            "#mariposa-der",
            { opacity: 0, x: 50, y: 20, rotation: 15, scale: 0.8 },
            {
                opacity: 1,
                x: 0,
                y: 0,
                rotation: 0,
                scale: 1,
                duration: 4,
                ease: "power2.out",
            },
        );

        gsap.to("#mariposa-der", {
            y: -12,
            rotation: -3,
            duration: 3,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
        });

        gsap.to("#mariposa-der", {
            x: -10,
            duration: 4,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
        });

        // NOMBRE - Efecto cascada letra por letra
        function nombreCascadaElegante() {
            const linea1 = "Danna";
            const linea2 = "Larissa";
            const contenedor = document.getElementById("nombre-typewriter");
            if (!contenedor) return;

            const letrasLinea1 = linea1
                .split("")
                .map(
                    (letra, index) =>
                        `<span class="letra-cascada" style="
                            --i: ${index};
                            opacity: 0;
                            display: inline-block;
                            transform: translateY(30px) scale(0.8);
                            filter: blur(2px);
                        ">${letra}</span>`,
                )
                .join("");

            const letrasLinea2 = linea2
                .split("")
                .map(
                    (letra, index) =>
                        `<span class="letra-cascada" style="
                            --i: ${linea1.length + index};
                            opacity: 0;
                            display: inline-block;
                            transform: translateY(30px) scale(0.8);
                            filter: blur(2px);
                        ">${letra}</span>`,
                )
                .join("");

            contenedor.innerHTML = `
                <span class="block">${letrasLinea1}</span>
                <span class="block">${letrasLinea2}</span>
            `;

            gsap.to(".letra-cascada", {
                opacity: 1,
                y: 0,
                scale: 1,
                filter: "blur(0px)",
                duration: 0.8,
                ease: "back.out(1.6)",
                stagger: { each: 0.12, from: "start" },
            });
        }

        // IMAGEN PRINCIPAL - Fade in con zoom
        gsap.fromTo(
            "#foto-container",
            { opacity: 0, scale: 0.8, y: 30 },
            { opacity: 1, scale: 1, y: 0, duration: 1.2, ease: "power2.out" },
        );

        nombreCascadaElegante();
    });
</script>

<style>
    .letra-cascada {
        transition: all 0.3s ease;
        will-change: transform, opacity, filter;
        position: relative;
    }

    .letra-cascada:hover {
        transform: translateY(-3px) scale(1.05) !important;
        text-shadow: 0 0 12px rgba(78, 104, 75, 0.5) !important;
    }
</style>
