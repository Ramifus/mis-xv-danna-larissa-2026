---
// Calendario.astro - CON CONFIGURACIÓN FÁCIL
---

<section class="py-8 px-6 sm:px-8 md:px-12 lg:px-16">
  <div class="max-w-3xl mx-auto relative">
    <!-- CONTENEDOR DEL CALENDARIO -->
    <div class="max-w-xl mx-auto px-4 relative">
      <!-- FLORES LATERALES IZQUIERDA - MÁS HACIA EL BORDE -->
      <div
        class="absolute -left-16 md:-left-28 lg:-left-40 top-24 md:top-28 w-24 md:w-32 lg:w-40 pointer-events-none z-0"
        id="flores-cal-izq"
      >
        <img
          src="/imagenes/FlorLateral.webp"
          alt="Flores"
          class="w-full h-auto object-contain scale-x-[-1]"
        />
      </div>

      <!-- FLORES LATERALES DERECHA - MÁS HACIA EL BORDE -->
      <div
        class="absolute -right-16 md:-right-28 lg:-right-40 top-24 md:top-28 w-24 md:w-32 lg:w-40 pointer-events-none z-0"
        id="flores-cal-der"
      >
        <img
          src="/imagenes/FlorLateral.webp"
          alt="Flores"
          class="w-full h-auto object-contain"
        />
      </div>

      <div
        class="rounded-2xl p-5 relative z-10"
        id="calendario-card"
        style="background: linear-gradient(150deg, #fffaf5 0%, #fef2e8 50%, #fffaf5 100%); border: 2px solid #c9a55e; box-shadow: 0 12px 40px rgba(162,119,53,0.18);"
      >
        <!-- Esquinas decorativas internas -->
        <div class="absolute top-3 left-3 w-7 h-7 pointer-events-none" style="border-top: 2px solid #a27735; border-left: 2px solid #a27735;"></div>
        <div class="absolute top-3 right-3 w-7 h-7 pointer-events-none" style="border-top: 2px solid #a27735; border-right: 2px solid #a27735;"></div>
        <div class="absolute bottom-3 left-3 w-7 h-7 pointer-events-none" style="border-bottom: 2px solid #a27735; border-left: 2px solid #a27735;"></div>
        <div class="absolute bottom-3 right-3 w-7 h-7 pointer-events-none" style="border-bottom: 2px solid #a27735; border-right: 2px solid #a27735;"></div>

        <!-- MARIPOSAS + TÍTULO DEL MES -->
        <div class="flex items-center justify-center gap-3 mb-2" id="titulo-mes-container">
          <div id="mariposa-cal-izq">
            <img src="/gif/MariposaRoja.gif" alt="Mariposa" class="w-8 h-8 object-contain" />
          </div>
          <h3 class="font-charm text-2xl text-[#a27735] font-bold tracking-wide" id="nombre-mes"></h3>
          <div id="mariposa-cal-der">
            <img src="/gif/MariposaRoja.gif" alt="Mariposa" class="w-8 h-8 object-contain scale-x-[-1]" />
          </div>
        </div>

        <!-- Separador ornamental -->
        <div class="flex items-center gap-2 mb-3">
          <div class="flex-1 h-px" style="background: linear-gradient(to right, transparent, #c9a55e);"></div>
          <span class="text-[#800020] text-xs leading-none">✦</span>
          <div class="flex-1 h-px" style="background: linear-gradient(to left, transparent, #c9a55e);"></div>
        </div>

        <!-- DÍAS DE LA SEMANA -->
        <div class="grid grid-cols-7 gap-1 mb-2 rounded-lg py-1.5" style="background: rgba(128,0,32,0.06);">
          <div class="text-center font-charm text-xs text-[#800020] font-bold">D</div>
          <div class="text-center font-charm text-xs text-[#800020] font-bold">L</div>
          <div class="text-center font-charm text-xs text-[#800020] font-bold">M</div>
          <div class="text-center font-charm text-xs text-[#800020] font-bold">M</div>
          <div class="text-center font-charm text-xs text-[#800020] font-bold">J</div>
          <div class="text-center font-charm text-xs text-[#800020] font-bold">V</div>
          <div class="text-center font-charm text-xs text-[#800020] font-bold">S</div>
        </div>

        <!-- DÍAS DEL MES -->
        <div class="grid grid-cols-7 gap-1" id="dias-container"></div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ═══════════════════════════════════════════════════════════
  // ⭐ CONFIGURACIÓN DE LA FECHA DE LA BODA ⭐
  // ═══════════════════════════════════════════════════════════
  // 🔧 EDITA ESTAS 3 VARIABLES PARA CAMBIAR LA FECHA:

  const DIA_ESPECIAL = 5; // ← Día de la boda (1-31)
  const MES_ESPECIAL = 7; // ← Mes de la boda (1-12)
  const AÑO_ESPECIAL = 2026; // ← Año de la boda

  // ═══════════════════════════════════════════════════════════

  // Nombres de los meses
  const NOMBRES_MESES = [
    "Enero",
    "Febrero",
    "Marzo",
    "Abril",
    "Mayo",
    "Junio",
    "Julio",
    "Agosto",
    "Septiembre",
    "Octubre",
    "Noviembre",
    "Diciembre",
  ];

  // Función para generar el calendario
  function generarCalendario() {
    const nombreMes = `${NOMBRES_MESES[MES_ESPECIAL - 1]} ${AÑO_ESPECIAL}`;
    document.getElementById("nombre-mes").textContent = nombreMes;

    // Calcular el primer día del mes (0 = domingo, 1 = lunes, etc.)
    const primerDia = new Date(AÑO_ESPECIAL, MES_ESPECIAL - 1, 1).getDay();

    // Calcular el último día del mes
    const ultimoDia = new Date(AÑO_ESPECIAL, MES_ESPECIAL, 0).getDate();

    const diasContainer = document.getElementById("dias-container");
    diasContainer.innerHTML = "";

    // Agregar espacios vacíos para días antes del primer día del mes
    for (let i = 0; i < primerDia; i++) {
      const espacioVacio = document.createElement("div");
      diasContainer.appendChild(espacioVacio);
    }

    // Agregar los días del mes
    for (let dia = 1; dia <= ultimoDia; dia++) {
      const diaDiv = document.createElement("div");

      if (dia === DIA_ESPECIAL) {
        diaDiv.className = "aspect-square flex items-center justify-center rounded-full dia-calendario";
        diaDiv.id = "dia-especial";
        diaDiv.style.cssText = "background: #a27735; box-shadow: 0 4px 16px rgba(162,119,53,0.6);";
        diaDiv.innerHTML = `<span class="font-charm text-lg text-white font-bold">${dia}</span>`;
      } else {
        diaDiv.className = "aspect-square flex items-center justify-center rounded-lg hover:bg-[#a27735]/10 transition-all dia-calendario";
        diaDiv.innerHTML = `<span class="font-charm text-sm text-gray-500">${dia}</span>`;
      }

      diasContainer.appendChild(diaDiv);
    }
  }

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      console.log("📅 Iniciando animaciones del calendario elegante...");

      // Generar el calendario
      generarCalendario();

      // 🎯 ESTADO INICIAL - FLORES EMPIEZAN MÁS ADENTRO PARA DESLIZARSE MÁS LEJOS
      gsap.set("#flores-cal-izq", { opacity: 0, x: 60 });
      gsap.set("#flores-cal-der", { opacity: 0, x: -60 });
      gsap.set("#calendario-card", { opacity: 0, scale: 0.95 });
      gsap.set("#mariposa-cal-izq", { opacity: 0, x: -20 });
      gsap.set("#mariposa-cal-der", { opacity: 0, x: 20 });
      gsap.set("#titulo-mes-container h3", { opacity: 0 });
      gsap.set(".dia-calendario", { opacity: 0 });

      // ✨ ANIMACIÓN EN DOS FASES
      ScrollTrigger.create({
        trigger: "#calendario-card",
        start: "top 85%",
        end: "top 20%",
        onEnter: () => animarCalendario(),
        onLeaveBack: () => ocultarCalendario(),
      });

      function animarCalendario() {
        const tl = gsap.timeline();

        // FASE 1: Calendario, mariposas, título y números aparecen JUNTOS Y RÁPIDO (0.6 seg)
        tl.to(
          "#calendario-card, #mariposa-cal-izq, #mariposa-cal-der, #titulo-mes-container h3, .dia-calendario",
          {
            opacity: 1,
            scale: 1,
            x: 0,
            duration: 0.6,
            ease: "power2.out",
          },
        )

          // FASE 2: Flores se deslizan MÁS LEJOS HACIA LOS BORDES (0.8 seg)
          .to(
            "#flores-cal-izq, #flores-cal-der",
            {
              opacity: 1,
              x: 0,
              duration: 0.8,
              ease: "power2.out",
            },
            "-=0.2",
          );
      }

      function ocultarCalendario() {
        gsap.set("#flores-cal-izq", { opacity: 0, x: 60 });
        gsap.set("#flores-cal-der", { opacity: 0, x: -60 });
        gsap.set("#calendario-card", { opacity: 0, scale: 0.95 });
        gsap.set("#mariposa-cal-izq", { opacity: 0, x: -20 });
        gsap.set("#mariposa-cal-der", { opacity: 0, x: 20 });
        gsap.set("#titulo-mes-container h3", { opacity: 0 });
        gsap.set(".dia-calendario", { opacity: 0 });
      }

      // 🦋 FLOTADO SUAVE DE MARIPOSAS
      gsap.to("#mariposa-cal-izq", {
        y: -8,
        duration: 3,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 1,
      });

      gsap.to("#mariposa-cal-der", {
        y: -8,
        duration: 3,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 1.2,
      });

      // ⭐ PULSO MUY SUAVE DEL DÍA ESPECIAL
      gsap.to("#dia-especial", {
        scale: 1.03,
        duration: 3,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 1.5,
      });

      console.log("📅✨ ¡Calendario elegante listo!");
    });
  }
</script>

<style>
  #dia-especial {
    box-shadow: 0 6px 20px rgba(162, 119, 53, 0.5);
  }
</style>
