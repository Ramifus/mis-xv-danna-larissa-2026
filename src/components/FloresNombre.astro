<section class="relative text-black w-full overflow-x-hidden">
    <!-- Fondo con desvanecimiento a transparente abajo -->
    <div
        class="absolute inset-0 z-0 pointer-events-none"
        style="background-image: url('/imagenes/fondomono.png'); background-size: 100% auto; background-position: center top; background-repeat: repeat-y; -webkit-mask-image: linear-gradient(to bottom, black 95%, transparent 100%); mask-image: linear-gradient(to bottom, black 95%, transparent 100%);"
    >
    </div>
    <div
        class="relative z-10 flex justify-center pt-36 sm:pt-40 md:pt-44"
        id="corona"
    >
        <img
            src="/imagenes/Corona.webp"
            alt="Corona de quinceañera"
            class="w-20 h-auto sm:w-24 md:w-28 lg:w-32 xl:w-36 object-contain"
        />
    </div>

    <div class="relative z-10 w-full pt-6 sm:pt-7 md:pt-8 overflow-hidden px-4">
        <div class="flex justify-center w-full">
            <div class="text-center z-10 max-w-4xl w-full">
                <div
                    class="relative text-center z-30 mb-4 w-full"
                    id="titulo-container"
                >
                    <h1
                        class="font-crimson text-2xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl text-[#800020] font-bold tracking-wider"
                        id="titulo"
                    >
                        MIS XV AÑOS
                    </h1>
                </div>

                <div
                    class="flex items-center justify-center mb-8 w-full"
                    id="nombre-container"
                >
                    <h2
                        class="font-great-vibes text-6xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-[#a27735] tracking-wide leading-none"
                        id="nombre-typewriter"
                    >
                    </h2>
                </div>

                <div
                    class="relative w-full overflow-visible"
                    id="foto-container"
                >
                    <div class="relative flex justify-center">
                        <div class="relative">
                            <img
                                src="/imagenes/Quinceañera.webp"
                                alt="Foto de quinceañera"
                                class="w-full max-w-[65vw] h-auto sm:max-w-[55vw] md:max-w-[45vw] lg:max-w-[38vw] xl:max-w-[32vw] object-contain"
                                id="foto-quinceañera"
                            />
                            <!-- 3 mariposas dispersas lado derecho, zona cabeza -->
                            <img
                                src="/gif/MariposaRoja.gif"
                                alt="Mariposa 1"
                                class="absolute -right-10 top-0 w-12 h-auto object-contain"
                                id="mari-1"
                            />
                            <img
                                src="/gif/MariposaRoja.gif"
                                alt="Mariposa 2"
                                class="absolute -right-4 top-20 w-8 h-auto object-contain scale-x-[-1]"
                                id="mari-2"
                            />
                            <img
                                src="/gif/MariposaRoja.gif"
                                alt="Mariposa 3"
                                class="absolute -right-12 top-36 w-8 h-auto object-contain"
                                id="mari-3"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        // CORONA - Zoom in
        gsap.fromTo(
            "#corona",
            { opacity: 0, scale: 0.5 },
            {
                opacity: 1,
                scale: 1,
                duration: 1.2,
                ease: "back.out(1.2)",
                delay: 0.3,
            },
        );

        // TÍTULO - Fade in de arriba
        gsap.fromTo(
            "#titulo",
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 1, ease: "power2.out", delay: 0.5 },
        );

        // MARIPOSAS - Aparecen desde la derecha
        gsap.fromTo(
            ["#mari-1", "#mari-2", "#mari-3"],
            { opacity: 0, x: 30 },
            {
                opacity: 1,
                x: 0,
                duration: 1,
                ease: "power2.out",
                stagger: 0.2,
                delay: 1.2,
            },
        );

        // MARIPOSA 1 - vuela: sube/baja + leve balanceo lateral
        gsap.to("#mari-1", {
            y: -10,
            duration: 2.6,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 2,
        });
        gsap.to("#mari-1", {
            x: 6,
            duration: 1.8,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 2,
        });

        // MARIPOSA 2 - vuela más rápido, balanceo opuesto
        gsap.to("#mari-2", {
            y: -8,
            duration: 2.0,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 2.2,
        });
        gsap.to("#mari-2", {
            x: -5,
            duration: 1.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 2.2,
        });

        // MARIPOSA 3 - vuela lento, balanceo suave
        gsap.to("#mari-3", {
            y: -6,
            duration: 3.0,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 2.5,
        });
        gsap.to("#mari-3", {
            x: 4,
            duration: 2.2,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 2.5,
        });

        // NOMBRE - Efecto cascada letra por letra
        function nombreCascadaElegante() {
            const linea1 = "Danna";
            const linea2 = "Larissa";
            const contenedor = document.getElementById("nombre-typewriter");
            if (!contenedor) return;

            const letrasLinea1 = linea1
                .split("")
                .map(
                    (letra, index) =>
                        `<span class="letra-cascada" style="
                            --i: ${index};
                            opacity: 0;
                            display: inline-block;
                            transform: translateY(30px) scale(0.8);
                            filter: blur(2px);
                        ">${letra}</span>`,
                )
                .join("");

            const letrasLinea2 = linea2
                .split("")
                .map(
                    (letra, index) =>
                        `<span class="letra-cascada" style="
                            --i: ${linea1.length + index};
                            opacity: 0;
                            display: inline-block;
                            transform: translateY(30px) scale(0.8);
                            filter: blur(2px);
                        ">${letra}</span>`,
                )
                .join("");

            contenedor.innerHTML = `
                <span class="block">${letrasLinea1}</span>
                <span class="block">${letrasLinea2}</span>
            `;

            gsap.to(".letra-cascada", {
                opacity: 1,
                y: 0,
                scale: 1,
                filter: "blur(0px)",
                duration: 0.8,
                ease: "back.out(1.6)",
                stagger: { each: 0.12, from: "start" },
            });
        }

        // IMAGEN PRINCIPAL - Fade in con zoom
        gsap.fromTo(
            "#foto-container",
            { opacity: 0, scale: 0.8, y: 30 },
            { opacity: 1, scale: 1, y: 0, duration: 1.2, ease: "power2.out" },
        );

        nombreCascadaElegante();
    });
</script>

<style>
    .letra-cascada {
        transition: all 0.3s ease;
        will-change: transform, opacity, filter;
        position: relative;
    }

    .letra-cascada:hover {
        transform: translateY(-3px) scale(1.05) !important;
        text-shadow: 0 0 12px rgba(78, 104, 75, 0.5) !important;
    }
</style>
