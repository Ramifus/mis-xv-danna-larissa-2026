<section class="py-8 px-4 relative">
  <div class="max-w-sm mx-auto">

    <div class="relative flex justify-center" id="flores-arriba-ded">
      <!-- Marco decorativo -->
      <img
        src="/imagenes/calendario.png"
        alt="Marco decorativo"
        class="w-full h-auto object-contain pointer-events-none select-none"
      />

      <!-- Texto encima del marco -->
      <div class="absolute inset-0 flex items-center justify-center px-10 pt-16 pb-8">
        <h2
          class="font-charm text-lg sm:text-xl text-[#800020] leading-relaxed text-center"
          id="texto-ded"
        >
          Los sueños se cumplen y hoy uno de los míos se hace realidad. Con la
          bendición de Dios y el amor de mi familia, te invito a celebrar mis 15
          años.
        </h2>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    console.log("💐 Iniciando animaciones de dedicatoria...");

    // Estado inicial - Todo oculto
    // Las flores de arriba se van hacia arriba (-30), el texto y las flores de abajo hacia abajo (+30)
    gsap.set("#flores-arriba-ded", { opacity: 0, y: -30 });
    gsap.set("#texto-ded", { opacity: 0, y: 30 });
    gsap.set("#flores-abajo-ded", { opacity: 0, y: 30 });

    // ScrollTrigger con entrada y salida
    ScrollTrigger.create({
      trigger: "#texto-ded",
      start: "top 100%", // Cuando el trigger toca el borde inferior de la ventana
      end: "top 20%", // Desaparece cuando el trigger llega al 20% superior de la ventana
      
      onEnter: () => {
        console.log("💐 Dedicatoria apareciendo...");
        animarEntrada();
      },

      onLeaveBack: () => {
        console.log("💐 Dedicatoria desapareciendo...");
        animarSalida();
      },
    });

    // ANIMACIÓN DE ENTRADA (ahora todos al mismo tiempo)
    function animarEntrada() {
      const tl = gsap.timeline();

      // INICIAMOS LA ANIMACIÓN DE LA FLOR SUPERIOR
      tl.to("#flores-arriba-ded", {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power2.out",
      })
      // AL MISMO TIEMPO (usando "<") animamos el TEXTO
      .to("#texto-ded", {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power2.out",
      }, "<") // <-- ¡CLAVE! Esto hace que inicie al mismo tiempo que la animación anterior.
      // AL MISMO TIEMPO (usando "<") animamos la FLOR INFERIOR
      .to("#flores-abajo-ded", {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power2.out",
      }, "<"); // <-- ¡CLAVE! Esto hace que inicie al mismo tiempo que la animación anterior.
    }

    // ANIMACIÓN DE SALIDA (se mantiene secuencial como estaba, desapareciendo de abajo hacia arriba)
    function animarSalida() {
      const tl = gsap.timeline();

      // Todo desaparece rápido
      tl.to("#flores-abajo-ded", {
        opacity: 0,
        y: 30,
        duration: 0.4,
        ease: "power2.in",
      })
      .to("#texto-ded", {
        opacity: 0,
        y: 30,
        duration: 0.4,
        ease: "power2.in",
      }, "-=0.3")
      .to("#flores-arriba-ded", {
        opacity: 0,
        y: -30,
        duration: 0.4,
        ease: "power2.in",
      }, "-=0.3");
    }
  });
</script>